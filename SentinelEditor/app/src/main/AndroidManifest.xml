<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Required permissions for GitHub API & network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Min SDK 26 for latest security -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    
    <application
        android:name="com.sentinel.SentinelApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SentinelEditor">
        
        <!-- MainActivity - App launcher -->
        <activity
            android:name="com.sentinel.editor.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.SentinelEditor">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- OAuthCallbackActivity - GitHub OAuth callback handler -->
        <activity
            android:name="com.sentinel.editor.utils.OAuthCallbackActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:permission="android:namecom.github.android.github.OAuthActivity"
            android:theme="@style/Theme.AppCompat.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                
                <!-- OAuth redirect scheme - MUST match OAuthCallbackActivity.handleOAuthCallback() scheme -->
                <data
                    android:scheme="github-oauth-callback://OAuthCallbackActivity.handleOAuthCallback"
                    android:host="callback" />
            </intent-filter>
        </activity>
        
        <!-- Privacy policy required for Google Play -->
        <meta-data
            android:name="com.google.android.gms privacy_policy_url"
            android:value="https://github.com/Tempuskg/sentinel-editor#privacy" />
        
        <!-- GitHub OAuth redirect scheme -->
        <meta-data
            android:name="com.github.android.github.oauth_redirect_scheme"
            android:value="github-oauth-callback://OAuthCallbackActivity.handleOAuthCallback" />
            
        <!-- GitHub OAuth client ID (from GitHub OAuth Apps) -->
        <meta-data
            android:name="com.github.android.github.oauth_client_id" 
            android:value="YOUR_CLIENT_ID_HERE" />
        
    </application>
</manifest>